generator client {
  provider = "prisma-client-js"
}

datasource db {
  // IMPORTANT: Render uses PostgreSQL (DATABASE_URL configured on Render dashboard)
  // Local dev: update .env to use the Supabase/Render PostgreSQL URL
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         String     @default("user")   // "admin" | "user"
  active       Boolean    @default(true)
  resetToken   String?
  resetExpiry  DateTime?
  createdAt    DateTime   @default(now())
  loginLogs    LoginLog[]
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id           Int           @id @default(autoincrement())
  name         String
  email        String
  phone        String        @unique
  company      String
  revenue      String?
  sector       String?
  stage        String        @default("Novo")
  inPipeline   Boolean       @default(false)
  tags         String        @default("[]") // JSON array stored as string: ["tag1", "tag2"]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  tasks        Task[]
  transactions Transaction[]
}

model Message {
  id        String   @id @default(cuid())
  contactId Int
  direction String
  text      String
  channel   String   @default("whatsapp")
  subject   String?
  timestamp DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Task {
  id        Int       @id @default(autoincrement())
  contactId Int
  title     String
  notes     String?
  dueDate   DateTime?
  priority  String    @default("Media")
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Automation {
  id           String  @id @default(cuid())
  trigger      String  // "new_contact", "form_submission", "contact_tag", "contact_revenue", "contact_sector"
  triggerValue String? // tag name, revenue range, or sector (for matching conditions)
  action       String  // "send_email", "send_template", "send_text", "update_stage"
  targetStage  String? // "Novo", "Contactado", etc. (for update_stage action)
  templateName String?
  emailSubject String?
  emailBody    String?
  active       Boolean @default(true)
}

model Form {
  id          String   @id @default(cuid())
  title       String
  description String?
  mode        String   @default("step")
  thankYouUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fields      FormField[]
  submissions FormSubmission[]
}

model FormField {
  id           String  @id @default(cuid())
  formId       String
  type         String
  label        String
  required     Boolean @default(false)
  order        Int
  options      String?
  contactField String?
  form         Form    @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers      FormAnswer[]
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  submittedAt DateTime @default(now())
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  answers     FormAnswer[]
}

model FormAnswer {
  id           String         @id @default(cuid())
  submissionId String
  fieldId      String
  value        String
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  field        FormField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                     String    @id @default(cuid())
  date                   DateTime
  clientId               Int?
  clientName             String?
  type                   String    // "entrada" | "saida"
  revenueType            String?   // "recorrente" | "one-off"
  contractDurationMonths Int?
  nextPaymentDate        DateTime?
  category               String
  subcategory            String?
  description            String?
  amountKz               Float
  currencyOrigin         String    @default("KZ") // KZ | CHF | EUR | USD
  exchangeRate           Float     @default(1.0)
  paymentMethod          String?
  status                 String    @default("pago") // "pago" | "pendente" | "atrasado"
  receiptNumber          String?
  notes                  String?
  deleted                Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  contact                Contact?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model FinancialCategory {
  id            String  @id @default(cuid())
  type          String  // "entrada" | "saida"
  category      String
  subcategories String? // JSON array as string: ["sub1","sub2"]
  color         String?
  icon          String?
  active        Boolean @default(true)
  sortOrder     Int     @default(0)

  @@unique([type, category])
}
