generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        Int                    @id @default(autoincrement())
  name                      String
  email                     String                 @unique
  passwordHash              String                 @default("SUPABASE_AUTH")
  resetToken                String?
  resetExpiry               DateTime?
  createdAt                 DateTime               @default(now())
  active                    Boolean                @default(true)
  role                      String                 @default("user")
  mustChangePassword        Boolean                @default(false)
  accountOwnerId            Int?
  supabaseUid               String?                @unique
  plan                      String                 @default("essencial")
  isSuperAdmin              Boolean                @default(false)
  permissions               String?
  jobTitle                  String?
  workspaceMode             String                 @default("servicos")
  assignedEstabelecimentoId String?
  billingType               String                 @default("trial")
  trialEndsAt               DateTime?
  expiresAt                 DateTime?
  graceEndsAt               DateTime?
  accountStatus             String                 @default("active")
  automations               Automation[]           @relation("AutomationUser")
  caixaSessoesFechadas      CaixaSessao[]          @relation("CaixaSessaoClosedBy")
  caixaSessoesAbertas       CaixaSessao[]          @relation("CaixaSessaoOpenedBy")
  caixaSessoes              CaixaSessao[]          @relation("CaixaSessaoUser")
  calendarSync              CalendarSync?
  chatChannelMemberships    ChatChannelMember[]    @relation("ChatMemberUser")
  chatMessagesSent          ChatMessage[]          @relation("ChatSenderUser")
  clientesFaturacao         ClienteFaturacao[]     @relation("ClienteFaturacaoUser")
  configuracaoFaturacao     ConfiguracaoFaturacao? @relation("ConfigFaturacaoUser")
  contacts                  Contact[]              @relation("ContactUser")
  contactFieldConfigs       ContactFieldConfig[]   @relation("ContactFieldConfigUser")
  contactFieldDefs          ContactFieldDef[]      @relation("ContactFieldDefUser")
  contactGroups             ContactGroup[]         @relation("ContactGroupUser")
  contactNotes              ContactNote[]          @relation("NoteAuthor")
  calendarEvents            CalendarEvent[]        @relation("CalendarEventUser")
  assignedCalendarEvents    CalendarEvent[]        @relation("CalendarEventAssignee")
  estabelecimentos          Estabelecimento[]      @relation("EstabelecimentoUser")
  facturas                  Factura[]              @relation("FacturaUser")
  facturaRecorrentes        FacturaRecorrente[]    @relation("FacturaRecorrenteUser")
  forms                     Form[]                 @relation("FormUser")
  googleCalendarEvents      GoogleCalendarEvent[]
  googleCalendarToken       GoogleCalendarToken?
  loginLogs                 LoginLog[]
  pipelineStages            PipelineStage[]        @relation("PipelineStageUser")
  produtos                  Produto[]              @relation("ProdutoUser")
  produtoCategorias         ProdutoCategoria[]     @relation("ProdutoCategoriaUser")
  saftPeriodos              SaftPeriodo[]          @relation("SaftPeriodoUser")
  series                    Serie[]                @relation("SerieUser")
  stockMovementsCreated     StockMovement[]        @relation("StockMovementCreatedBy")
  stockMovements            StockMovement[]        @relation("StockMovementUser")
  assignedTasks             Task[]                 @relation("TaskAssignee")
  tasks                     Task[]                 @relation("TaskUser")
  transactions              Transaction[]          @relation("TransactionUser")
  accountOwner              User?                  @relation("AccountMembers", fields: [accountOwnerId], references: [id])
  accountMembers            User[]                 @relation("AccountMembers")
  assignedEstabelecimento   Estabelecimento?       @relation("AssignedEstabelecimento", fields: [assignedEstabelecimentoId], references: [id])
  automationLogs            AutomationLog[]
  automationAlerts          AutomationAlert[]
  dailyTipDeliveries        DailyTipDelivery[]
  startupTemplateApplied    StartupTemplateApplication? @relation("StartupTemplateOrganization")
  startupTemplatesAppliedBy StartupTemplateApplication[] @relation("StartupTemplateAppliedBy")

  @@index([assignedEstabelecimentoId])
  @@index([accountStatus])
  @@index([expiresAt])
  @@index([trialEndsAt])
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id              Int              @id @default(autoincrement())
  name            String
  email           String
  phone           String
  company         String
  revenue         String?
  sector          String?
  location        String?
  birthDate       DateTime?
  lastActivityAt  DateTime?
  stage           String           @default("Novo")
  inPipeline      Boolean          @default(false)
  tags            String           @default("[]")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userId          Int?
  customFields    String           @default("{}")
  contactType     String           @default("interessado")
  documents       String           @default("[]")
  status          String           @default("ativo")
  clienteType     String           @default("particular")
  nif             String?
  dealValueKz     Float?
  contactGroupId  String?
  contactGroup    ContactGroup?    @relation(fields: [contactGroupId], references: [id], onDelete: SetNull)
  user            User?            @relation("ContactUser", fields: [userId], references: [id], onDelete: SetNull)
  notes           ContactNote[]
  formSubmissions FormSubmission[]
  calendarEvents  CalendarEvent[]
  messages        Message[]
  tasks           Task[]
  transactions    Transaction[]
  automationLogs  AutomationLog[]
  automationAlerts AutomationAlert[]

  @@unique([userId, phone], name: "user_phone_unique")
  @@index([contactGroupId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, inPipeline])
  @@index([userId, stage])
  @@index([userId, lastActivityAt])
  @@index([userId, birthDate])
}

model ContactGroup {
  id             String    @id @default(cuid())
  userId         Int
  name           String
  normalizedName String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation("ContactGroupUser", fields: [userId], references: [id], onDelete: Cascade)
  contacts       Contact[]

  @@unique([userId, normalizedName])
}

model ContactNote {
  id        Int      @id @default(autoincrement())
  contactId Int
  userId    Int?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user      User?    @relation("NoteAuthor", fields: [userId], references: [id])
}

model ContactFieldDef {
  id        String   @id @default(cuid())
  userId    Int
  label     String
  key       String
  type      String   @default("text")
  options   String?
  required  Boolean  @default(false)
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation("ContactFieldDefUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model PipelineStage {
  id        String   @id @default(cuid())
  userId    Int
  name      String
  color     String   @default("#6b7e9a")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation("PipelineStageUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model ContactFieldConfig {
  id       String  @id @default(cuid())
  userId   Int
  fieldKey String
  label    String
  visible  Boolean @default(true)
  required Boolean @default(false)
  order    Int     @default(0)
  user     User    @relation("ContactFieldConfigUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fieldKey])
}

model Message {
  id        String   @id @default(cuid())
  contactId Int
  direction String
  text      String
  channel   String   @default("whatsapp")
  subject   String?
  timestamp DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model Task {
  id                      Int       @id @default(autoincrement())
  contactId               Int?
  title                   String
  notes                   String?
  dueDate                 DateTime?
  priority                String    @default("Media")
  done                    Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  userId                  Int?
  assignedToUserId        Int?
  googleCalendarEventId   String?
  googleCalendarHtmlLink  String?
  googleCalendarSyncError String?
  googleCalendarSyncedAt  DateTime?
  source                  String    @default("manual")
  automationId            String?
  assignedTo              User?     @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  contact                 Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user                    User?     @relation("TaskUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([assignedToUserId])
  @@index([userId, dueDate])
  @@index([contactId])
  @@index([userId, source])
  @@index([automationId])
}

model Automation {
  id                   String          @id @default(cuid())
  trigger              String
  triggerValue         String?
  action               String
  targetStage          String?
  templateName         String?
  emailSubject         String?
  emailBody            String?
  active               Boolean         @default(true)
  userId               Int?
  formId               String?
  taskAssignedToUserId Int?
  taskDueDays          Int?
  taskNotes            String?
  taskPriority         String?
  taskTitle            String?
  form                 Form?           @relation(fields: [formId], references: [id])
  user                 User?           @relation("AutomationUser", fields: [userId], references: [id])
  logs                 AutomationLog[]
  alerts               AutomationAlert[]
}

model AutomationAlert {
  id           String      @id @default(cuid())
  userId       Int
  contactId    Int?
  automationId String?
  type         String
  title        String
  message      String?
  status       String      @default("open")
  createdAt    DateTime    @default(now())
  resolvedAt   DateTime?
  automation   Automation? @relation(fields: [automationId], references: [id], onDelete: SetNull)
  contact      Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([contactId])
  @@index([automationId])
  @@map("automation_alert")
}

model AutomationLog {
  id              String     @id @default(cuid())
  automation_id   String
  organization_id Int
  trigger_type    String
  trigger_data    Json
  action_type     String
  action_data     Json
  success         Boolean
  error_message   String?
  contact_id      Int?
  duration_ms     Int?
  created_at      DateTime   @default(now())
  automation      Automation @relation(fields: [automation_id], references: [id], onDelete: Cascade)
  contact         Contact?   @relation(fields: [contact_id], references: [id])
  organization    User       @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([automation_id, created_at])
  @@index([organization_id, created_at])
  @@index([organization_id, success])
  @@index([contact_id])
  @@map("automation_log")
}

model ActivityLog {
  id              String   @id @default(cuid())
  organization_id Int
  entity_type     String
  entity_id       String
  entity_label    String
  action          String
  field_changed   String?
  old_value       String?
  new_value       String?
  user_id         Int
  user_name       String
  metadata        Json?
  created_at      DateTime @default(now())

  @@index([organization_id, created_at])
  @@index([entity_type, entity_id])
  @@map("activity_log")
}

model Form {
  id                String           @id @default(cuid())
  title             String
  description       String?
  mode              String           @default("step")
  thankYouUrl       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  userId            Int?
  bgColor           String?
  brandColor        String?
  logoUrl           String?
  googleTagEnabled  Boolean          @default(false)
  googleTagId       String?
  metaPixelEnabled  Boolean          @default(false)
  metaPixelId       String?
  trackSubmitAsLead Boolean          @default(true)
  automations       Automation[]
  user              User?            @relation("FormUser", fields: [userId], references: [id])
  fields            FormField[]
  submissions       FormSubmission[]
}

model FormField {
  id           String       @id @default(cuid())
  formId       String
  type         String
  label        String
  required     Boolean      @default(false)
  order        Int
  options      String?
  contactField String?
  answers      FormAnswer[]
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model FormSubmission {
  id                String       @id @default(cuid())
  formId            String
  submittedAt       DateTime     @default(now())
  contactId         Int?
  contactSyncStatus String       @default("skipped")
  answers           FormAnswer[]
  contact           Contact?     @relation(fields: [contactId], references: [id])
  form              Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model FormAnswer {
  id           String         @id @default(cuid())
  submissionId String
  fieldId      String?
  value        String
  contactField String?
  fieldLabel   String?
  field        FormField?     @relation(fields: [fieldId], references: [id])
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                     String       @id @default(cuid())
  date                   DateTime
  clientId               Int?
  clientName             String?
  type                   String
  revenueType            String?
  contractDurationMonths Int?
  nextPaymentDate        DateTime?
  category               String
  subcategory            String?
  description            String?
  amountKz               Float
  currencyOrigin         String       @default("KZ")
  exchangeRate           Float        @default(1.0)
  paymentMethod          String?
  status                 String       @default("pago")
  receiptNumber          String?
  notes                  String?
  deleted                Boolean      @default(false)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  userId                 Int?
  cashSessionId          String?      @map("cash_session_id")
  invoiceId              String?      @map("invoice_id")
  reconciled             Boolean      @default(false)
  reconciledAt           DateTime?    @map("reconciled_at")
  attachments            String       @default("[]")
  cashSession            CaixaSessao? @relation("TransactionCashSession", fields: [cashSessionId], references: [id])
  contact                Contact?     @relation(fields: [clientId], references: [id])
  invoice                Factura?     @relation("TransactionInvoice", fields: [invoiceId], references: [id])
  user                   User?        @relation("TransactionUser", fields: [userId], references: [id])

  @@index([invoiceId])
  @@index([cashSessionId])
  @@index([userId, invoiceId])
  @@index([userId, cashSessionId])
}

model FinancialCategory {
  id            String  @id @default(cuid())
  type          String
  category      String
  subcategories String?
  color         String?
  icon          String?
  active        Boolean @default(true)
  sortOrder     Int     @default(0)

  @@unique([type, category])
}

model GoogleCalendarToken {
  id                String    @id @default(cuid())
  userId            Int       @unique
  accessToken       String
  refreshToken      String?
  expiresAt         DateTime
  googleEmail       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastSyncAt        DateTime?
  lastSyncError     String?
  lastSyncErrorAt   DateTime?
  primaryCalendarId String    @default("primary")
  provider          String    @default("google")
  scope             String?
  status            String    @default("connected")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id                      String    @id @default(cuid())
  userId                  Int
  contactId               Int?
  assignedToUserId        Int?
  title                   String
  notes                   String?
  startDate               DateTime
  endDate                 DateTime
  syncWithGoogle          Boolean   @default(false)
  googleCalendarEventId   String?
  googleCalendarHtmlLink  String?
  googleCalendarSyncError String?
  googleCalendarSyncedAt  DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  assignedTo              User?     @relation("CalendarEventAssignee", fields: [assignedToUserId], references: [id])
  contact                 Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  user                    User      @relation("CalendarEventUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([assignedToUserId, startDate])
  @@index([contactId])
  @@index([userId, startDate])
  @@index([googleCalendarEventId])
}

model GoogleCalendarEvent {
  id              String    @id @default(cuid())
  userId          Int
  calendarId      String    @default("primary")
  googleEventId   String
  title           String
  description     String?
  location        String?
  startAt         DateTime
  endAt           DateTime
  isAllDay        Boolean   @default(false)
  status          String    @default("confirmed")
  htmlLink        String?
  sourceUpdatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, calendarId, googleEventId])
  @@index([userId, startAt])
  @@index([userId, endAt])
  @@index([userId, status])
}

model CalendarSync {
  id           String   @id @default(cuid())
  userId       Int      @unique
  channelId    String   @unique
  resourceId   String
  channelToken String
  syncToken    String?
  watchExpiry  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Estabelecimento {
  id                 String              @id @default(cuid())
  userId             Int
  nome               String
  nif                String
  morada             String?
  telefone           String?
  email              String?
  isPrincipal        Boolean             @default(false)
  createdAt          DateTime            @default(now())
  defaultSerieId     String?
  caixaSessoes       CaixaSessao[]
  defaultSerie       Serie?              @relation("EstabelecimentoDefaultSerie", fields: [defaultSerieId], references: [id])
  user               User                @relation("EstabelecimentoUser", fields: [userId], references: [id], onDelete: Cascade)
  facturas           Factura[]
  facturaRecorrentes FacturaRecorrente[]
  series             Serie[]             @relation("EstabelecimentoSeries")
  assignedUsers      User[]              @relation("AssignedEstabelecimento")
}

model Serie {
  id                         String              @id @default(cuid())
  userId                     Int
  estabelecimentoId          String
  seriesCode                 String
  seriesYear                 Int
  documentType               String
  firstDocumentNumber        Int                 @default(1)
  lastDocumentNumber         Int?
  seriesStatus               String              @default("A")
  createdAt                  DateTime            @default(now())
  defaultForEstabelecimentos Estabelecimento[]   @relation("EstabelecimentoDefaultSerie")
  facturas                   Factura[]
  facturaRecorrentes         FacturaRecorrente[]
  estabelecimento            Estabelecimento     @relation("EstabelecimentoSeries", fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  user                       User                @relation("SerieUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesCode, seriesYear, documentType])
}

model ClienteFaturacao {
  id                 String              @id @default(cuid())
  userId             Int
  customerTaxID      String
  customerName       String
  customerAddress    String?
  customerPhone      String?
  customerEmail      String?
  contactId          Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation("ClienteFaturacaoUser", fields: [userId], references: [id], onDelete: Cascade)
  facturas           Factura[]
  facturaRecorrentes FacturaRecorrente[]

  @@unique([userId, customerTaxID])
}

model ProdutoCategoria {
  id        String    @id @default(cuid())
  userId    Int
  nome      String
  cor       String?   @default("#6b7e9a")
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  produtos  Produto[]
  user      User      @relation("ProdutoCategoriaUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nome])
}

model Produto {
  id                 String            @id @default(cuid())
  userId             Int
  productCode        String
  productDescription String
  unitPrice          Float             @default(0)
  unitOfMeasure      String            @default("UN")
  taxPercentage      Float             @default(14)
  taxCode            String            @default("NOR")
  active             Boolean           @default(true)
  createdAt          DateTime          @default(now())
  cost               Float?
  productType        String            @default("S")
  sku                String?
  barcode            String?
  stock              Int?              @default(0)
  categoriaId        String?
  stockMinimo        Int?              @default(0)
  categoria          ProdutoCategoria? @relation(fields: [categoriaId], references: [id])
  user               User              @relation("ProdutoUser", fields: [userId], references: [id], onDelete: Cascade)
  stockMovements     StockMovement[]

  @@unique([userId, productCode])
}

model StockMovement {
  id              String   @id @default(cuid())
  productId       String
  userId          Int
  type            String
  quantity        Int
  previousStock   Int
  newStock        Int
  reason          String?
  notes           String?
  createdByUserId Int
  referenceType   String?
  referenceId     String?
  createdAt       DateTime @default(now())
  createdBy       User     @relation("StockMovementCreatedBy", fields: [createdByUserId], references: [id])
  product         Produto  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user            User     @relation("StockMovementUser", fields: [userId], references: [id])
}

model Factura {
  id                   String            @id @default(cuid())
  userId               Int
  documentNo           String
  documentType         String
  serieId              String
  estabelecimentoId    String
  documentDate         DateTime          @default(now())
  documentStatus       String            @default("N")
  documentCancelReason String?
  customerTaxID        String
  customerName         String
  customerAddress      String?
  clienteFaturacaoId   String?
  lines                String
  netTotal             Float
  taxPayable           Float
  grossTotal           Float
  qrCodeUrl            String?
  qrCodeImage          String?
  jwsSignature         String            @default("PLACEHOLDER")
  agtRequestId         String?
  agtValidationStatus  String            @default("P")
  agtSubmittedAt       DateTime?
  isOffline            Boolean           @default(false)
  offlineEmittedAt     DateTime?
  offlineSubmittedAt   DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  currencyAmount       Float?
  currencyCode         String            @default("AOA")
  exchangeRate         Float?
  paymentMethod        String            @default("Transferência Bancária")
  hashCode             String?
  hashControl          String?
  caixaSessaoId        String?
  baseCurrency         String            @default("AOA")
  displayCurrency      String            @default("AOA")
  displayMode          String            @default("DOCUMENT_ONLY")
  exchangeRateDate     DateTime?
  caixaSessao          CaixaSessao?      @relation(fields: [caixaSessaoId], references: [id])
  clienteFaturacao     ClienteFaturacao? @relation(fields: [clienteFaturacaoId], references: [id])
  estabelecimento      Estabelecimento   @relation(fields: [estabelecimentoId], references: [id])
  serie                Serie             @relation(fields: [serieId], references: [id])
  user                 User              @relation("FacturaUser", fields: [userId], references: [id], onDelete: SetNull)
  financeTransactions  Transaction[]     @relation("TransactionInvoice")

  @@unique([userId, documentNo])
}

model CaixaSessao {
  id                    String          @id @default(cuid())
  userId                Int
  estabelecimentoId     String
  openedByUserId        Int
  closedByUserId        Int?
  openedAt              DateTime        @default(now())
  closedAt              DateTime?
  openingBalance        Float           @default(0)
  closingCountedAmount  Float?
  expectedClosingAmount Float?
  differenceAmount      Float?
  totalSalesAmount      Float           @default(0)
  salesCount            Int             @default(0)
  status                String          @default("open")
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  totalCash             Float           @default(0)
  totalMulticaixa       Float           @default(0)
  totalTransferencia    Float           @default(0)
  totalTpa              Float           @default(0)
  closedBy              User?           @relation("CaixaSessaoClosedBy", fields: [closedByUserId], references: [id])
  estabelecimento       Estabelecimento @relation(fields: [estabelecimentoId], references: [id])
  openedBy              User            @relation("CaixaSessaoOpenedBy", fields: [openedByUserId], references: [id])
  user                  User            @relation("CaixaSessaoUser", fields: [userId], references: [id])
  facturas              Factura[]
  financeTransactions   Transaction[]   @relation("TransactionCashSession")
}

model SaftPeriodo {
  id            String   @id @default(cuid())
  userId        Int
  periodo       String
  startDate     DateTime
  endDate       DateTime
  status        String   @default("GENERATED")
  xmlContent    String?
  totalFacturas Int      @default(0)
  generatedAt   DateTime @default(now())
  user          User     @relation("SaftPeriodoUser", fields: [userId], references: [id], onDelete: Cascade)
}

model AuditoriaEvento {
  id         String   @id @default(cuid())
  userId     Int?
  eventType  String
  entityType String
  entityId   String
  eventData  String?
  errorData  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model FacturaRecorrente {
  id                 String            @id @default(cuid())
  userId             Int
  serieId            String
  estabelecimentoId  String
  clienteFaturacaoId String?
  customerTaxID      String
  customerName       String
  customerAddress    String?
  documentType       String            @default("FT")
  lines              String
  currencyCode       String            @default("AOA")
  exchangeRate       Float?
  paymentMethod      String            @default("Transferência Bancária")
  frequency          String
  startDate          DateTime
  nextRunDate        DateTime
  lastRunDate        DateTime?
  lastFacturaId      String?
  isActive           Boolean           @default(true)
  totalGenerated     Int               @default(0)
  maxOccurrences     Int?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  baseCurrency       String            @default("AOA")
  displayCurrency    String            @default("AOA")
  displayMode        String            @default("DOCUMENT_ONLY")
  exchangeRateDate   DateTime?
  clienteFaturacao   ClienteFaturacao? @relation(fields: [clienteFaturacaoId], references: [id])
  estabelecimento    Estabelecimento   @relation(fields: [estabelecimentoId], references: [id])
  serie              Serie             @relation(fields: [serieId], references: [id])
  user               User              @relation("FacturaRecorrenteUser", fields: [userId], references: [id], onDelete: Cascade)
}

model ConfiguracaoFaturacao {
  id                       String    @id @default(cuid())
  userId                   Int       @unique
  nifEmpresa               String    @default("")
  nomeEmpresa              String    @default("")
  moradaEmpresa            String    @default("")
  agtMockMode              Boolean   @default(true)
  agtCertNumber            String    @default("PENDING")
  contingencyMode          Boolean   @default(false)
  contingencyActivatedAt   DateTime?
  defaultSerieId           String?
  defaultEstabelecimentoId String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  iban                     String    @default("")
  logoUrl                  String?
  emailEmpresa             String    @default("")
  telefoneEmpresa          String    @default("")
  websiteEmpresa           String    @default("")
  user                     User      @relation("ConfigFaturacaoUser", fields: [userId], references: [id], onDelete: Cascade)
}

model ChatChannel {
  id          String              @id @default(cuid())
  orgId       Int
  name        String
  description String?
  type        String              @default("channel")
  createdById Int
  createdAt   DateTime            @default(now())
  members     ChatChannelMember[]
  messages    ChatMessage[]

  @@index([orgId])
}

model ChatChannelMember {
  id         String      @id @default(cuid())
  channelId  String
  userId     Int
  joinedAt   DateTime    @default(now())
  lastReadAt DateTime?
  channel    ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user       User        @relation("ChatMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model ChatMessage {
  id          String      @id @default(cuid())
  channelId   String
  senderId    Int
  text        String
  attachments String      @default("[]")
  mentions    String      @default("[]")
  createdAt   DateTime    @default(now())
  channel     ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender      User        @relation("ChatSenderUser", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}

model OnboardingProgress {
  id              String    @id @default(cuid())
  organization_id String
  workspace_mode  String
  flow_key        String    @default("onboarding_v2")
  completed_steps String[]  @default([])
  dismissed       Boolean   @default(false)
  dismissed_at    DateTime?
  completed_at    DateTime?
  reopened_at     DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@unique([organization_id, workspace_mode, flow_key])
}

model StartupTemplateApplication {
  id              String    @id @default(cuid())
  organizationId  Int       @unique
  templateKey     String
  workspaceMode   String
  appliedAt       DateTime  @default(now())
  appliedByUserId Int?
  metadata        Json?
  organization    User      @relation("StartupTemplateOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  appliedByUser   User?     @relation("StartupTemplateAppliedBy", fields: [appliedByUserId], references: [id], onDelete: SetNull)

  @@index([templateKey])
  @@index([workspaceMode])
}

model DailyTipDelivery {
  id                   String    @id @default(cuid())
  userId               Int
  deliveryDate         String    @map("delivery_date")
  workspaceMode        String    @map("workspace_mode")
  audienceBucket       String    @map("audience_bucket")
  tipId                String    @map("tip_id")
  payload              Json?
  createdAt            DateTime  @default(now()) @map("created_at")
  dismissedAt          DateTime? @map("dismissed_at")
  dismissedInDashboard Boolean   @default(false) @map("dismissed_in_dashboard")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deliveryDate])
  @@index([deliveryDate])
  @@map("daily_tip_delivery")
}

model MessagingCampaign {
  id                        String                       @id @default(cuid())
  provider                  String                       @default("ZIETT")
  providerCampaignId        String?
  name                      String
  content                   String
  channelType               String                       @default("SMS")
  remitterId                String
  countryAlpha2             String                       @default("AO")
  requestedRecipientsCount  Int                          @default(0)
  acceptedRecipientsCount   Int                          @default(0)
  invalidRecipientsCount    Int                          @default(0)
  duplicateRecipientsCount  Int                          @default(0)
  optedOutRecipientsCount   Int                          @default(0)
  notAllowedRecipientsCount Int                          @default(0)
  status                    String                       @default("pending")
  providerStatus            String?
  triggerSource             String                       @default("SUPERADMIN_PANEL")
  createdByUserId           Int
  createdByEmail            String
  accountOwnerId            Int?
  workspaceMode             String?
  isTest                    Boolean                      @default(true)
  statusNote                String?
  providerErrorCode         String?
  providerErrorMessage      String?
  providerTraceId           String?
  rawRequestJson            Json?
  rawResponseJson           Json?
  sentAt                    DateTime?
  processedAt               DateTime?
  completedAt               DateTime?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  recipients                MessagingCampaignRecipient[]
  messages                  MessagingMessageLog[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([providerCampaignId])
  @@index([createdByUserId])
}

model MessagingCampaignRecipient {
  id                 String                @id @default(cuid())
  campaignId         String
  phoneOriginal      String
  phoneNormalized    String?
  contactId          Int?
  contactName        String?
  contactEmail       String?
  status             String                @default("pending")
  providerMessageId  String?
  providerStatus     String?
  channelDestination String?
  cost               Float?
  errorCode          String?
  errorMessage       String?
  rawProviderJson    Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  campaign           MessagingCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  messageLogs        MessagingMessageLog[]

  @@index([campaignId, createdAt])
  @@index([phoneNormalized])
  @@index([providerMessageId])
}

model MessagingMessageLog {
  id                   String                      @id @default(cuid())
  provider             String                      @default("ZIETT")
  providerMessageId    String?
  campaignId           String?
  campaignRecipientId  String?
  content              String
  phoneOriginal        String
  phoneNormalized      String
  contactId            Int?
  channelType          String                      @default("SMS")
  remitterId           String
  status               String                      @default("pending")
  providerStatus       String?
  channelDestination   String?
  cost                 Float?
  triggerSource        String                      @default("SUPERADMIN_PANEL")
  createdByUserId      Int
  createdByEmail       String
  isTest               Boolean                     @default(true)
  providerErrorCode    String?
  providerErrorMessage String?
  providerTraceId      String?
  rawRequestJson       Json?
  rawResponseJson      Json?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  campaign             MessagingCampaign?          @relation(fields: [campaignId], references: [id])
  campaignRecipient    MessagingCampaignRecipient? @relation(fields: [campaignRecipientId], references: [id])

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([providerMessageId])
  @@index([campaignId])
  @@index([campaignRecipientId])
}

model MessagingOptOut {
  id              String   @id @default(cuid())
  phoneNormalized String   @unique
  reason          String?
  source          String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}
